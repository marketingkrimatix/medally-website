    "preview": "vite preview",
    "generate-sitemap": "node scripts/generate-sitemap.mjs",
    "generate-image-sitemap": "ts-node scripts/generate-image-sitemap.ts",
    "update-sitemaps": "ts-node scripts/update-sitemaps.ts",
    "compile-scripts": "tsc -p tsconfig.scripts.json",
    "update-sitemaps-js": "npm run compile-scripts && node dist-scripts/update-sitemaps.js",
    "test": "echo 'No tests specified' && exit 0"
  },
