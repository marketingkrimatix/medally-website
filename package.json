    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@sanity/client": "7.20.0",
    "@sanity/image-url": "2.1.0",
    "@testing-library/react": "16.1.0",
    "@types/recharts": "1.8.29",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "framer-motion": "10.18.0",
